#!/usr/bin/env bash
# garminbridge, control the bridge and free the watch for other apps.
# (This script is also installed as 'garmin-voice', a legacy alias; same commands.)
#
#   garminbridge voice        import voice notes now (alias: sync). Passes flags like --delete.
#   garminbridge activities   back up activity .fit files now (copy-only).
#   garminbridge pause        turn auto-import OFF and release the watch (for Garmin
#                             Express, OpenMTP, etc.). Survives reconnects until 'resume'.
#   garminbridge resume       turn auto-import back ON.
#   garminbridge free         release the watch from this tool and macOS PTPCamera right now
#                             (one-shot). Use when "the Mac won't see the watch", then open your app.
#   garminbridge root [PATH]  show / set the single output root (a "Garmin Bridge" folder with
#                             Voice Memo + Backups inside). No PATH prints the current root.
#   garminbridge device [N]   optional sub-level under the root for several watches / an Edge /
#                             users (e.g. "Fenix 8"). 'device none' clears it.
#   garminbridge migrate      move existing files from the legacy ~/Documents folders into the root.
#   garminbridge status       show current state.

set -uo pipefail
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPORT="$SELF_DIR/export-voice-notes.sh"
ACTIVITIES="$SELF_DIR/backup-activities.sh"
LABEL="com.garminvoice.watcher"
UID_NUM="$(id -u)"
PAUSE_FLAG="${GVE_PAUSE_FLAG:-$HOME/.config/garmin-voice-export/paused}"
GVE_CONFIG="${GVE_CONFIG:-$HOME/.config/garmin-voice-export/config}"
[ -f "$GVE_CONFIG" ] && . "$GVE_CONFIG"            # source first so config can set the destination
. "$SELF_DIR/gve-paths.sh"; gve_resolve_paths      # organised "Garmin Bridge" root (legacy default if unset)
DEST="$GVE_VOICE_DEST"
ACT_DEST="$GVE_ACT_DEST"
mkdir -p "$(dirname "$PAUSE_FLAG")"

# release every process that holds the watch's single USB interface
free_device(){
  pkill -9 -f "export-voice-notes.sh" 2>/dev/null
  pkill -9 -x gphoto2 2>/dev/null
  killall PTPCamera 2>/dev/null
  rm -rf /tmp/garmin_voice_export.lock 2>/dev/null
}

# upsert/remove a KEY=VALUE in the config file (used by the menu-bar app + CLI)
cfg_set(){ mkdir -p "$(dirname "$GVE_CONFIG")"; touch "$GVE_CONFIG"
  grep -vE "^$1=" "$GVE_CONFIG" > "$GVE_CONFIG.tmp" 2>/dev/null || true; mv "$GVE_CONFIG.tmp" "$GVE_CONFIG"
  printf "%s='%s'\n" "$1" "$2" >> "$GVE_CONFIG"; }   # single-quote so paths with spaces survive sourcing
cfg_unset(){ [ -f "$GVE_CONFIG" ] || return 0
  grep -vE "^$1=" "$GVE_CONFIG" > "$GVE_CONFIG.tmp" 2>/dev/null || true; mv "$GVE_CONFIG.tmp" "$GVE_CONFIG"; }

# move files from a legacy folder into an organised-layout folder. Merges/dedups the
# manifest and appends the log if both sides have one; never overwrites a data file.
migrate_one(){ local src="$1" dst="$2" lbl="$3" f bn n=0
  [ -d "$src" ] || { echo "  $lbl: nothing at $src"; return 0; }
  [ "$src" = "$dst" ] && { echo "  $lbl: already in place"; return 0; }
  mkdir -p "$dst"
  shopt -s nullglob dotglob 2>/dev/null
  for f in "$src"/*; do
    [ -e "$f" ] || continue
    bn="$(basename "$f")"
    case "$bn" in
      .synced.tsv)            if [ -f "$dst/.synced.tsv" ]; then cat "$f" >> "$dst/.synced.tsv"; rm -f "$f"; else mv -f "$f" "$dst/"; fi; continue ;;
      export.log|backup.log)  if [ -f "$dst/$bn" ]; then cat "$f" >> "$dst/$bn"; rm -f "$f"; else mv -f "$f" "$dst/"; fi; continue ;;
      .DS_Store)              rm -f "$f"; continue ;;
    esac
    if [ -e "$dst/$bn" ]; then echo "  skip (already there): $bn"; else mv -f "$f" "$dst/" && n=$((n+1)); fi
  done
  [ -f "$dst/.synced.tsv" ] && { awk -F'\t' '!seen[$1]++' "$dst/.synced.tsv" > "$dst/.synced.tsv.tmp" && mv "$dst/.synced.tsv.tmp" "$dst/.synced.tsv"; }
  echo "  $lbl: moved $n file(s) -> $dst"; }

case "${1:-status}" in
  pause|off|stop)
    touch "$PAUSE_FLAG"; free_device
    echo "⏸  Auto-import PAUSED and the watch released."
    echo "   It stays free across reconnects — Garmin Express / OpenMTP / MTP tools will see it."
    echo "   Re-enable with:  garmin-voice resume" ;;
  resume|on|start)
    rm -f "$PAUSE_FLAG"
    echo "▶  Auto-import RESUMED. New memos import on the next connect." ;;
  free|release|fix)
    free_device
    echo "✓  Released the watch from this tool and macOS PTPCamera."
    echo "   Open Garmin Express / your MTP app now — it should connect."
    echo "   (One-shot. To keep it free across reconnects use:  garmin-voice pause)" ;;
  voice|import|sync|now)
    shift; free_device; sleep 1; exec "$EXPORT" "$@" ;;
  activities|backup)
    shift; free_device; sleep 1; exec "$ACTIVITIES" "$@" ;;
  root)
    if [ -z "${2:-}" ]; then echo "${GARMIN_BRIDGE_ROOT:-(unset — using the legacy ~/Documents layout)}"; exit 0; fi
    cfg_set GARMIN_BRIDGE_ROOT "$2"
    cfg_unset GARMIN_VOICE_DEST; cfg_unset GARMIN_ACTIVITY_DEST     # let the root layout actually apply
    GARMIN_BRIDGE_ROOT="$2"; unset GARMIN_VOICE_DEST GARMIN_ACTIVITY_DEST; gve_resolve_paths
    mkdir -p "$GVE_VOICE_DEST/Archive" "$GVE_ACT_DEST" 2>/dev/null
    echo "output root -> $2"
    echo "  voice notes -> $GVE_VOICE_DEST"
    echo "  backups     -> $GVE_ACT_DEST"
    echo "  move existing files in with:  garminbridge migrate" ;;
  device)
    case "${2:-}" in
      "")          echo "${GARMIN_BRIDGE_DEVICE:-(none)}" ;;
      none|--none) cfg_unset GARMIN_BRIDGE_DEVICE; echo "device sub-folder cleared" ;;
      *)           cfg_set GARMIN_BRIDGE_DEVICE "$2"; echo "device sub-folder -> $2 (under the output root)" ;;
    esac ;;
  migrate)
    echo "Migrating legacy files into the organised layout…"
    migrate_one "$HOME/Documents/Voice Memos" "$DEST" "voice"
    migrate_one "$HOME/Documents/Garmin Activities" "$ACT_DEST" "backups"
    echo "Done." ;;
  status)
    echo "GarminBridge status"
    echo "  auto-import : $([ -f "$PAUSE_FLAG" ] && echo 'PAUSED' || echo 'active')"
    if launchctl print "gui/$UID_NUM/$LABEL" >/dev/null 2>&1; then echo "  watcher     : installed (instant on-connect)"; else echo "  watcher     : not installed (run bin/install-autorun.sh)"; fi
    echo "  destination : $DEST"
    echo "  output root : ${GARMIN_BRIDGE_ROOT:-legacy ~/Documents layout}${GARMIN_BRIDGE_DEVICE:+  (device: $GARMIN_BRIDGE_DEVICE)}"
    case "${GARMIN_VOICE_DELETE:-}" in
      ""|0|keep|no|off)             dm="keep on watch" ;;
      transcribed|after-transcript) dm="after transcript" ;;
      *)                            dm="after verified copy" ;;
    esac
    echo "  delete-from-watch : $dm"
    echo "  local retention   : $([ -n "${GVE_AUDIO_RETENTION_DAYS:-}" ] && echo "drop audio after ${GVE_AUDIO_RETENTION_DAYS}d, keep transcript" || echo 'keep audio')"
    echo "  transcription     : $([ "${GVE_TRANSCRIBE:-0}" = 1 ] && echo "on (${GVE_TRANSCRIBE_BACKEND:-parakeet})" || echo 'off')"
    echo "  transcript cleanup: $([ "${GVE_TRANSCRIPT_CLEANUP:-0}" = 1 ] && echo "on (${GVE_CLEANUP_BACKEND:-openai})" || echo 'off')"
    echo "  activity backup   : $([ "${GARMIN_ACTIVITY_BACKUP:-0}" = 1 ] && echo "on -> $ACT_DEST" || echo 'off')" ;;
  set)   cfg_set "$2" "$3"; echo "set $2" ;;
  unset) cfg_unset "$2"; echo "unset $2" ;;
  get)   [ -f "$GVE_CONFIG" ] && grep -E "^$2=" "$GVE_CONFIG" | head -1 | cut -d= -f2- | sed "s/^['\"]//; s/['\"]$//" || true ;;
  -h|--help|help)
    grep '^#' "$0" | grep -v '^#!' | sed 's/^# \{0,1\}//' ;;
  *) echo "usage: garminbridge {status|voice|activities|pause|resume|free|root [PATH]|device [NAME]|migrate|set KEY VAL|unset KEY}" >&2; exit 2 ;;
esac
